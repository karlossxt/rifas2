      onRegisterWinner,
      onDeleteWinner,
      onApproveTicket,
      onRejectTicket
    }) {
      const [price, setPrice] = useState(config.pricePerTicket);
      const [endDate, setEndDate] = useState(config.endCelebrationDate);
      
      const [prize1, setPrize1] = useState(config.prize1);
      const [img1, setImg1] = useState(config.img1);
      const [prize2, setPrize2] = useState(config.prize2);
      const [img2, setImg2] = useState(config.img2);
      const [prize3, setPrize3] = useState(config.prize3);
      const [img3, setImg3] = useState(config.img3);

      const [winName, setWinName] = useState('');
      const [winTicket, setWinTicket] = useState('');
      const [winPrize, setWinPrize] = useState('');
      const [winImg, setWinImg] = useState('');

      // Inner search fields completely corrected with local hooks
      const [searchBoleto, setSearchBoleto] = useState('');
      const [foundRes, setFoundRes] = useState(null);
      const [searchedNum, setSearchedNum] = useState('');

      const handleSaveAjustes = (e) => {
        e.preventDefault();
        onUpdateConfig({
          pricePerTicket: Number(price),
          endCelebrationDate: endDate,
          prize1, img1,
          prize2, img2,
          prize3, img3
        });
        alert('¡Ajustes guardados exitosamente!');
      };

      const handleRegisterWinnerSubmit = (e) => {
        e.preventDefault();
        if (!winName || !winTicket || !winPrize) {
          alert('Por favor introduce los datos obligatorios del ganador.');
          return;
        }
        onRegisterWinner({
          name: winName,
          ticket: winTicket,
          prize: winPrize,
          img: winImg || "https://images.unsplash.com/photo-1509198397868-475647b2a1e5?auto=format&fit=crop&w=400&q=80"
        });
        setWinName('');
        setWinTicket('');
        setWinPrize('');
        setWinImg('');
        alert('Ganador registrado con éxito.');
      };

      const handleSearchValidateLocal = (e) => {
        e.preventDefault();
        if (!searchBoleto.trim()) {
          setFoundRes(null);
          setSearchedNum('');
          return;
        }
        const num = searchBoleto.trim();
        const res = reservations[num];
        setSearchedNum(num);
        setFoundRes(res || { ticketNumber: num, status: 'available' });
      };

      const handleSearchClearLocal = () => {
        setSearchBoleto('');
        setFoundRes(null);
        setSearchedNum('');
      };

      const handleImgUpload = (e, setImgState) => {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onloadend = () => {
            setImgState(reader.result);
          };
          reader.readAsDataURL(file);
        }
      };

      const handleDownloadCSV = () => {
        const headers = ["Boleto", "Luchador/Comprador", "WhatsApp", "Estado de Pago", "Fecha Registro"];
        const rows = Object.values(reservations).map(r => [
          r.ticketNumber,
          r.name,
          r.whatsapp,
          r.status.toUpperCase(),
          new Date(r.createdAt).toLocaleString()
        ]);
        
        let csvContent = "data:text/csv;charset=utf-8,\uFEFF"; 
        csvContent += [headers.join(","), ...rows.map(e => e.map(val => `"${val}"`).join(","))].join("\n");
        
        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", `Reporte_Taquilla_Sorteo_${endDate.replace(/\s+/g, '_')}.csv`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      };

