    function App() {
      const [config, setConfig] = useState(() => {
        try {
          const stored = localStorage.getItem(LOCAL_STORAGE_CONFIG_KEY);
          if (stored) {
            return JSON.parse(stored);
          }
        } catch (e) {
          console.warn("No se pudo acceder a localStorage para cargar configuración:", e);
        }
        return DEFAULT_CONFIG;
      });

      const [reservations, setReservations] = useState(() => {
        try {
          const stored = localStorage.getItem(LOCAL_STORAGE_DB_KEY);
          if (stored) {
            return JSON.parse(stored);
          }
        } catch (e) {
          console.warn("No se pudo acceder a localStorage para cargar reservas:", e);
        }
        return {};
      });

      const [winners, setWinners] = useState(() => {
        try {
          const stored = localStorage.getItem(LOCAL_STORAGE_WINNERS_KEY);
          if (stored) {
            return JSON.parse(stored);
          }
        } catch (e) {
          console.warn("No se pudo acceder a localStorage para cargar reservas:", e);
        }
        return DEFAULT_WINNERS;
      });

      const [selectedTickets, setSelectedTickets] = useState(new Set());
      const [showAdmin, setShowAdmin] = useState(false);
      const [adminPassword, setAdminPassword] = useState('');
      const [showPasswordPrompt, setShowPasswordPrompt] = useState(false);
      const [successInfo, setSuccessInfo] = useState(null);
      const [logoClicks, setLogoClicks] = useState(0);

      const [activeModal, setActiveModal] = useState(null);

      const handleLogoClick = (e) => {
        e.preventDefault();
        setLogoClicks((prev) => {
          const next = prev + 1;
          if (next >= 5) {
            setShowPasswordPrompt(true);
            return 0;
          }
          return next;
        });
      };

      useEffect(() => {
        try {
          localStorage.setItem(LOCAL_STORAGE_DB_KEY, JSON.stringify(reservations));
        } catch (e) {
          console.warn("No se pudo escribir en localStorage:", e);
        }
      }, [reservations]);

      useEffect(() => {
        try {
          localStorage.setItem(LOCAL_STORAGE_CONFIG_KEY, JSON.stringify(config));
        } catch (e) {
          console.warn("No se pudo escribir en localStorage:", e);
        }
      }, [config]);

      useEffect(() => {
        try {
          localStorage.setItem(LOCAL_STORAGE_WINNERS_KEY, JSON.stringify(winners));
        } catch (e) {
          console.warn("No se pudo escribir en localStorage:", e);
        }
      }, [winners]);

      const handleToggleTicket = (num) => {
        if (reservations[num]) return;

        setSelectedTickets((prev) => {
          const next = new Set(prev);
          if (next.has(num)) {
            next.delete(num);
          } else {
            next.add(num);
          }
          return next;
        });
      };

      const handleClearSelection = () => {
        setSelectedTickets(new Set());
      };

      const handleSelectRandom = (count) => {
        const availableList = [];
        for (let i = 0; i < config.totalTickets; i++) {
          const num = TICKET_POOL[i] || String(i).padStart(5, '0');
          if (!reservations[num] && !selectedTickets.has(num)) {
            availableList.push(num);
          }
        }

        if (availableList.length === 0) {
          alert('¡Vaya! No quedan boletos disponibles en esta categoría.');
          return;
        }

        const nextSelected = new Set(selectedTickets);
        const numToPick = Math.min(count, availableList.length);

        for (let i = 0; i < numToPick; i++) {
          const randIndex = Math.floor(Math.random() * availableList.length);
          const picked = availableList.splice(randIndex, 1)[0];
          nextSelected.add(picked);
        }

        setSelectedTickets(nextSelected);
      };

      const handleConfirmReservation = (name, whatsapp, receiptDataUrl) => {
        if (selectedTickets.size === 0) return;

        const timestamp = new Date().toISOString();
        const newReservations = { ...reservations };
        const ticketsArray = Array.from(selectedTickets);

        ticketsArray.forEach((num) => {
          newReservations[num] = {
            ticketNumber: num,
            name,
            whatsapp,
            receiptUrl: receiptDataUrl,
            status: 'pending',
            createdAt: timestamp,
          };
        });

        setReservations(newReservations);
        setSuccessInfo({
          name,
          tickets: ticketsArray,
          total: ticketsArray.length * config.pricePerTicket,
        });
        setSelectedTickets(new Set());
      };

      const handleApproveTicket = (num) => {
        setReservations((prev) => {
          if (!prev[num]) return prev;
          return {
            ...prev,
            [num]: {
              ...prev[num],
              status: 'approved',
            },
          };
        });
      };

      const handleRejectTicket = (num) => {
        setReservations((prev) => {
          const next = { ...prev };
          delete next[num];
          return next;
        });
      };

      const handleUpdateConfig = (newConfig) => {
        setConfig((prev) => ({ ...prev, ...newConfig }));
        
