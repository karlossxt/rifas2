      // 7. Random tickets quick select action
      document.getElementById('random-generator-btn').addEventListener('click', () => {
        const count = parseInt(document.getElementById('random-count-select').value, 10);
        const available = [];
        for (let i = 0; i < config.totalTickets; i++) {
          const num = TICKET_POOL[i] || String(i).padStart(6, '0');
          if (!reservations[num] && !selectedTickets.has(num)) {
            available.push(num);
          }
        }

        if (available.length === 0) {
          alert('¡Vaya! No quedan boletos disponibles.');
          return;
        }

        const pickedCount = Math.min(count, available.length);
        const shuffled = [...available].sort(() => 0.5 - Math.random());
        for (let i = 0; i < pickedCount; i++) {
          selectedTickets.add(shuffled[i]);
