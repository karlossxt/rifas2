    // --- TICKET GENERATOR & SELECTION ---
    function renderTickets() {
      const grid = document.getElementById('tickets-grid');
      grid.innerHTML = '';

      let total = config.totalTickets;
      let countReserved = Object.keys(reservations).length;
      let countSelected = selectedTickets.size;
      let countAvailable = total - countReserved;

      document.getElementById('count-all').textContent = total;
      document.getElementById('count-available').textContent = countAvailable;
      document.getElementById('count-reserved').textContent = countReserved;
      document.getElementById('count-selected').textContent = countSelected;

      let hasRenderedItems = false;

      for (let i = 0; i < total; i++) {
        const num = TICKET_POOL[i] || String(i).padStart(6, '0');
        const reservation = reservations[num];
        const isSelected = selectedTickets.has(num);
        const status = reservation ? reservation.status : null;

        let matchesFilter = true;
        if (currentFilter === 'available') {
          matchesFilter = !reservation && !isSelected;
        } else if (currentFilter === 'reserved') {
          matchesFilter = !!reservation;
        } else if (currentFilter === 'selected') {
          matchesFilter = isSelected;
        }

        if (searchQuery && !num.includes(searchQuery)) {
          matchesFilter = false;
        }

        if (!matchesFilter) continue;
        hasRenderedItems = true;

        const button = document.createElement('button');
        button.type = 'button';
        button.title = reservation ? `${reservation.name} (${status === 'pending' ? 'Apartado' : 'Vendido'})` : `Boleto #${num}`;
        
        let btnClass = "h-9 border rounded-lg text-[10px] font-black transition-all flex items-center justify-center tracking-tight shadow-sm hover:scale-105 active:scale-95 ";

        if (isSelected) {
          // Changed as requested: Only show the clover emoji (🍀), background is solid red, number is hidden
          btnClass += "bg-[#d91d2a] text-white border-[#d91d2a] font-black shadow-[0_0_12px_rgba(217,29,42,0.45)]";
          button.innerHTML = `<span class="text-sm">🍀</span>`;
        } else if (status === 'pending') {
          btnClass += "bg-amber-950/25 border-amber-500/20 text-amber-500/60 pointer-events-none line-through";
          button.innerHTML = `<span>${num}</span>`;
        } else if (status === 'approved') {
          btnClass += "bg-red-950/20 border-lucha-red/25 text-lucha-red/40 pointer-events-none line-through";
          button.innerHTML = `<span>${num}</span>`;
        } else {
          btnClass += "bg-[#0a0a0d] border-[#22222a] hover:border-lucha-green hover:bg-zinc-900 text-white cursor-pointer";
          button.innerHTML = `<span>${num}</span>`;
        }

        button.className = btnClass;
        button.addEventListener('click', () => {
          if (reservation) return;
          toggleTicket(num);
        });

        grid.appendChild(button);
      }

      const noResults = document.getElementById('tickets-no-results');
      if (!hasRenderedItems) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    }

    function toggleTicket(num) {
      if (selectedTickets.has(num)) {
        selectedTickets.delete(num);
      } else {
        selectedTickets.add(num);
      }
      renderTickets();
      updateCartUI();
    }

    // --- SHOPPING CART & TOTALS ---
    function updateCartUI() {
      const placeholder = document.getElementById('cart-empty-placeholder');
      const formContainer = document.getElementById('cart-form-container');

      if (selectedTickets.size === 0) {
        placeholder.classList.remove('hidden');
        formContainer.classList.add('hidden');
        return;
      }

      placeholder.classList.add('hidden');
      formContainer.classList.remove('hidden');

      const selectedArray = Array.from(selectedTickets);
      const totalCost = selectedArray.length * config.pricePerTicket;

      document.getElementById('cart-total-amount').textContent = `$${totalCost} MXN`;
      document.getElementById('payment-concept-text').textContent = `LUCHA ${selectedArray[0]}`;

      const badgesContainer = document.getElementById('cart-selected-badges');
      badgesContainer.innerHTML = '';
      selectedArray.forEach(num => {
        const badge = document.createElement('span');
        badge.className = "bg-lucha-red text-white text-[9px] font-black px-2 py-0.5 rounded";
        badge.textContent = `#${num}`;
        badgesContainer.appendChild(badge);
      });
    }

    // --- SUGGESTIONS RANDOM CHIPS ---
    function shuffleSuggestions() {
      const available = [];
      for (let i = 0; i < config.totalTickets; i++) {
        const num = TICKET_POOL[i] || String(i).padStart(6, '0');
        if (!reservations[num] && !selectedTickets.has(num)) {
          available.push(num);
        }
      }
      const shuffled = [...available].sort(() => 0.5 - Math.random());
      suggestions = shuffled.slice(0, 5);

      const container = document.getElementById('suggestions-buttons-container');
      container.innerHTML = '';

      if (suggestions.length === 0) {
        document.getElementById('suggestions-bar').classList.add('hidden');
        return;
      }
      document.getElementById('suggestions-bar').classList.remove('hidden');

      suggestions.forEach(num => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = "bg-zinc-900 hover:bg-lucha-gold hover:text-black border border-lucha-border text-[9px] text-white font-black px-2.5 py-1 rounded-lg transition-all cursor-pointer";
        chip.textContent = `#${num}`;
        chip.addEventListener('click', () => {
          toggleTicket(num);
        });
        container.appendChild(chip);
      });
    }

