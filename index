      onClearSelection,
      onSelectRandom,
    }) {
      const [filter, setFilter] = useState('all');
      const [randomCount, setRandomCount] = useState(1);
      const [searchQuery, setSearchQuery] = useState('');
      const [searchFilter, setSearchFilter] = useState('');
      const [suggestions, setSuggestions] = useState([]);

      useEffect(() => {
        const available = [];
        for (let i = 0; i < totalTickets; i++) {
          const num = TICKET_POOL[i] || String(i).padStart(6, '0');
          if (!reservations[num] && !selectedTickets.has(num)) {
            available.push(num);
          }
        }
        const shuffled = [...available].sort(() => 0.5 - Math.random());
        setSuggestions(shuffled.slice(0, 5));
      }, [reservations, selectedTickets, totalTickets]);

      const handleSearchSubmit = (e) => {
        e.preventDefault();
        if (!searchQuery.trim()) {
          setSearchFilter('');
          return;
        }
        setSearchFilter(searchQuery.trim());
      };

      const handleSearchClear = () => {
        setSearchQuery('');
        setSearchFilter('');
      };

      const handleShuffleSuggestions = () => {
        const available = [];
        for (let i = 0; i < totalTickets; i++) {
          const num = TICKET_POOL[i] || String(i).padStart(6, '0');
          if (!reservations[num] && !selectedTickets.has(num)) {
            available.push(num);
          }
        }
        const shuffled = [...available].sort(() => 0.5 - Math.random());
        setSuggestions(shuffled.slice(0, 5));
      };

      const tickets = [];
      for (let i = 0; i < totalTickets; i++) {
        const num = TICKET_POOL[i] || String(i).padStart(6, '0');
        const reservation = reservations[num];
        const isSelected = selectedTickets.has(num);
        const status = reservation ? reservation.status : null;
        
        let matches = true;

        if (filter === 'available') {
          matches = !reservation && !isSelected;
        } else if (filter === 'reserved') {
          matches = !!reservation;
        } else if (filter === 'selected') {
          matches = isSelected;
        }

        if (searchFilter && !num.includes(searchFilter)) {
          matches = false;
        }
        
        if (matches) {
          tickets.push({ num, isSelected, status, reservation });
        }
      }

