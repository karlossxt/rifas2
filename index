    function openSuccessModal(buyerName, ticketsArray) {
      const modal = document.getElementById('success-modal');
      document.getElementById('success-buyer-name').textContent = buyerName;
      document.getElementById('success-tickets').textContent = ticketsArray.map(t => `#${t}`).join(', ');
      
      const totalAmount = ticketsArray.length * config.pricePerTicket;
      document.getElementById('success-total').textContent = `$${totalAmount} MXN`;

      const formattedTickets = ticketsArray.map(t => `%23${t}`).join(', ');
      const waUrl = `https://wa.me/52${config.whatsappAdmin}?text=Hola,%20acabo%20de%20reservar%20los%20boletos%20${formattedTickets}%20a%20nombre%20de%20${encodeURIComponent(buyerName)}.%20Por%20favor%20validar%20mi%20pago.%20Gracias!`;
      
      document.getElementById('success-whatsapp-btn').href = waUrl;
      modal.classList.remove('hidden');
    }
    function closeSuccessModal() {
      document.getElementById('success-modal').classList.add('hidden');
    }

    function openPolicyModal(type) {
      document.getElementById('policy-modal').classList.remove('hidden');
      if (type === 'privacidad') {
        document.getElementById('policy-privacy-content').classList.remove('hidden');
        document.getElementById('policy-rules-content').classList.add('hidden');
      } else {
        document.getElementById('policy-privacy-content').classList.add('hidden');
        document.getElementById('policy-rules-content').classList.remove('hidden');
      }
    }
    function closePolicyModal() {
      document.getElementById('policy-modal').classList.add('hidden');
    }

    function bindAdminFileUploader(fileInputId, textInputId, labelId = null) {
      document.getElementById(fileInputId).addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onloadend = () => {
            document.getElementById(textInputId).value = reader.result;
            if (labelId) {
              document.getElementById(labelId).textContent = "✓ Imagen Cargada";
            }
          };
          reader.readAsDataURL(file);
        }
      });
    }

    // Start App Execution
    window.addEventListener('DOMContentLoaded', init);
  </script>
</body>
</html>
