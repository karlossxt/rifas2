            const next = { ...prev };
            let modified = false;
            Object.keys(next).forEach((num) => {
              const index = TICKET_POOL.indexOf(num);
              if (index >= newConfig.totalTickets || index === -1) {
                delete next[num];
                modified = true;
              }
            });
            return modified ? next : prev;
          });

          setSelectedTickets((prev) => {
            const next = new Set(prev);
            let modified = false;
            next.forEach((num) => {
              const index = TICKET_POOL.indexOf(num);
              if (index >= newConfig.totalTickets || index === -1) {
                next.delete(num);
                modified = true;
              }
            });
            return modified ? next : prev;
          });
        }
